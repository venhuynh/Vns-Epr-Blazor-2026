@using Microsoft.AspNetCore.Mvc.ViewFeatures

<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    @DxResourceManager.RegisterScripts()
    @DxResourceManager.RegisterTheme(Themes.Fluent)
    <link href="@Assets["_content/Vns-Epr-Blazor-2026.Shared/bootstrap/bootstrap.min.css"]" rel="stylesheet" />
    <link href="@Assets["_content/Vns-Epr-Blazor-2026.Shared/app.css"]" rel="stylesheet" />
    <link href="@Assets["Vns-Epr-Blazor-2026.Web.styles.css"]" rel="stylesheet" />
    <link href="@Assets["_content/Vns-Epr-Blazor-2026.Shared/favicon.png"]" rel="icon" type="image/png" />
    <ImportMap />
    <HeadOutlet @rendermode="RenderModeForPage" />
</head>

<body>
    <Routes @rendermode="RenderModeForPage" />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>

@code {
    [CascadingParameter]
    HttpContext HttpContext { get; set; } = default!;

    /// <summary>
    /// Account pages (Login, Logout, etc.) render STATICALLY so they can access HttpContext.
    /// All other pages use InteractiveAuto.
    /// Ref: DevExpress BlazorDemo.Showcase App.razor line 59
    /// </summary>
    IComponentRenderMode? RenderModeForPage =>
        HttpContext.Request.Path.StartsWithSegments("/Account")
            ? null
            : new InteractiveAutoRenderMode(false);
}
