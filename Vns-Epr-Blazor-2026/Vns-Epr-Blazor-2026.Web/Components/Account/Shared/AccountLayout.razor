@inherits LayoutComponentBase

<div class="account-layout">
    @Body
</div>

<style>
    .account-layout {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #1e3c72 0%, #2a5298 50%, #1e3c72 100%);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .login-container {
        background: rgba(255, 255, 255, 0.95);
        border-radius: 16px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        padding: 48px 40px;
        width: 100%;
        max-width: 440px;
        backdrop-filter: blur(10px);
    }

    .login-logo {
        text-align: center;
        margin-bottom: 32px;
    }

    .title-text {
        font-size: 28px;
        font-weight: 700;
        color: #1e3c72;
    }

    .subtitle-text {
        color: #6c757d;
        margin-top: 4px;
        font-size: 14px;
    }

    .form-input {
        width: 100%;
    }

    .btn-login {
        padding: 12px;
        font-size: 16px;
        font-weight: 600;
        border-radius: 8px;
        margin-top: 8px;
    }

    .remember-check {
        font-size: 14px;
        color: #6c757d;
    }

    .copyright {
        text-align: center;
        margin-top: 24px;
        font-size: 12px;
        color: #adb5bd;
    }
</style>
