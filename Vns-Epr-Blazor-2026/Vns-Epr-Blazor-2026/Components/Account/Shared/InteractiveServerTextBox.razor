@rendermode InteractiveServer

<DxTextBox name="@Name" Password="Password" CssClass="@CssClass" @bind-Text="Value" Enabled="@Enabled" ShowValidationIcon="@ShowValidationIcon"/>

@code {
    [Parameter] public string? Name { get; set; }
    [Parameter] public string? Value { get; set; }
    [Parameter] public bool Password { get; set; }
    [Parameter] public string? CssClass { get; set; }
    [Parameter] public bool Enabled { get; set; } = true;
    [Parameter] public bool ShowValidationIcon { get; set; }
}
