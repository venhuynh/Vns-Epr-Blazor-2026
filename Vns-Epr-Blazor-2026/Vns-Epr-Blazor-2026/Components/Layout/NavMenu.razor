@inject NavigationManager NavigationManager
@implements IDisposable

<div>
    @* --- Mobile Auth Menu (User profile / Log in) --- *@
    <DxMenu Orientation="@Orientation.Vertical" CssClass="menu display-mobile">
        <Items>
            <AuthorizeView>
                <Authorized>
                    <DxMenuItem NavigateUrl="Account/Manage" Text="@context.User.Identity?.Name" CssClass="@MenuItemCssClass("/Account/Manage")" IconCssClass="icon icon-user"></DxMenuItem>
                    <DxMenuItem NavigateUrl="Account/Logout" Text="Log out" CssClass="@MenuItemCssClass("/Account/Logout")" IconCssClass="icon icon-log-out"></DxMenuItem>
                </Authorized>
                <NotAuthorized>
                    <DxMenuItem NavigateUrl="Account/Login" Text="Log in" CssClass="@MenuItemCssClass("/Account/Login")" IconCssClass="icon icon-log-in"></DxMenuItem>
                </NotAuthorized>
            </AuthorizeView>
        </Items>
    </DxMenu>

    @* --- Main Navigation (visible to all authenticated users) --- *@
    <DxMenu Orientation="@Orientation.Vertical" CssClass="menu">
        <Items>
            <DxMenuItem NavigateUrl="/" Text="Home" CssClass="@MenuItemCssClass("/")" IconCssClass="icon icon-home"></DxMenuItem>
            <DxMenuItem NavigateUrl="/dashboard" Text="Dashboard" CssClass="@MenuItemCssClass("/dashboard")" IconCssClass="icon icon-counter"></DxMenuItem>
        </Items>
    </DxMenu>

    @* --- Admin Navigation (SuperAdmin + Admin only) --- *@
    <AuthorizeView Roles="SuperAdmin, Admin">
        <Authorized>
            <DxMenu Orientation="@Orientation.Vertical" CssClass="menu">
                <Items>
                    <DxMenuItem NavigateUrl="/admin/users" Text="User Management" CssClass="@MenuItemCssClass("/admin/users")" IconCssClass="icon icon-user"></DxMenuItem>
                </Items>
            </DxMenu>
        </Authorized>
    </AuthorizeView>

    @* --- SuperAdmin-only Navigation --- *@
    <AuthorizeView Roles="SuperAdmin">
        <Authorized>
            <DxMenu Orientation="@Orientation.Vertical" CssClass="menu">
                <Items>
                    <DxMenuItem NavigateUrl="/admin/settings" Text="System Settings" CssClass="@MenuItemCssClass("/admin/settings")" IconCssClass="icon icon-settings"></DxMenuItem>
                </Items>
            </DxMenu>
        </Authorized>
    </AuthorizeView>

    @* --- Account Settings (all authenticated) --- *@
    <DxMenu Orientation="@Orientation.Vertical" CssClass="menu">
        <Items>
            <DxMenuItem NavigateUrl="Account/Manage" Text="My Account" CssClass="@MenuItemCssClass("/Account/Manage")" IconCssClass="icon icon-settings"></DxMenuItem>
        </Items>
    </DxMenu>
</div>

@code {
    private string? currentLocalPath;

    protected override void OnInitialized() {
        currentLocalPath = new Uri(NavigationManager.Uri).LocalPath;
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e) {
        currentLocalPath = new Uri(NavigationManager.Uri).LocalPath;
        InvokeAsync(StateHasChanged);
    }

    private string? MenuItemCssClass(string itemPath) {
        return string.Equals(currentLocalPath, itemPath, StringComparison.OrdinalIgnoreCase) ? "menu-item-active" : null;
    }

    public void Dispose() {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}