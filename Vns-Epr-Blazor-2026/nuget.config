<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="DevExpress" value="https://nuget.devexpress.com/ZR8tuJN6MjP2tcu6kBFABEQd6NschwhgTLGTgr34JeF3mWikIn/api/v3/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="DevExpress">
      <package pattern="DevExpress.*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
