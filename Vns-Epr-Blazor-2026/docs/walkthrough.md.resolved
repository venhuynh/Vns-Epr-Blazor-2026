## Changes Made

### [NavMenu.razor](file:///c:/Users/Admin/source/Workspaces/2026/Vns-Epr-Blazor-2026/Vns-Epr-Blazor-2026/Vns-Epr-Blazor-2026/Components/Layout/NavMenu.razor)

Replaced the flat menu with RBAC-segmented sections:

| Section | Items | Visibility |
|---|---|---|
| Main Navigation | Home, Dashboard | All authenticated users |
| Admin Navigation | User Management | `SuperAdmin, Admin` |
| SuperAdmin Navigation | System Settings | `SuperAdmin` only |
| Account | My Account | All authenticated users |

```diff:NavMenu.razor
@inject NavigationManager NavigationManager
@implements IDisposable

<div>
    <DxMenu Orientation="@Orientation.Vertical" CssClass="menu display-mobile">
        <Items>
            <AuthorizeView>
                <Authorized>
                    <DxMenuItem NavigateUrl="Account/Manage" Text="@context.User.Identity?.Name" CssClass="@MenuItemCssClass("/Account/Manage")" IconCssClass="icon icon-user"></DxMenuItem>
                    <DxMenuItem NavigateUrl="Account/Logout" Text="Log out" CssClass="@MenuItemCssClass("/Account/Logout")" IconCssClass="icon icon-log-out"></DxMenuItem>
                </Authorized>
                <NotAuthorized>
                    <DxMenuItem NavigateUrl="Account/Login" Text="Log in" CssClass="@MenuItemCssClass("/Account/Login")" IconCssClass="icon icon-log-in"></DxMenuItem>
                </NotAuthorized>
            </AuthorizeView>
        </Items>
    </DxMenu>
    <DxMenu Orientation="@Orientation.Vertical" CssClass="menu">
        <Items>
            <DxMenuItem NavigateUrl="/" Text="Home" CssClass="@MenuItemCssClass("/")" IconCssClass="icon icon-home"></DxMenuItem>
            <DxMenuItem NavigateUrl="/counter" Text="Counter" CssClass="@MenuItemCssClass("/counter")" IconCssClass="icon icon-counter"></DxMenuItem>
            <DxMenuItem NavigateUrl="/weather" Text="Weather" CssClass="@MenuItemCssClass("/weather")" IconCssClass="icon icon-weather"></DxMenuItem>
            <DxMenuItem NavigateUrl="Account/Manage" Text="Settings" CssClass="@MenuItemCssClass("/Account/Manage")" IconCssClass="icon icon-settings"></DxMenuItem>
        </Items>
    </DxMenu>
</div>

@code {
    private string? currentLocalPath;

    protected override void OnInitialized() {
        currentLocalPath = new Uri(NavigationManager.Uri).LocalPath;
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e) {
        currentLocalPath = new Uri(NavigationManager.Uri).LocalPath;
        InvokeAsync(StateHasChanged);
    }

    private string? MenuItemCssClass(string itemPath) {
        return string.Equals(currentLocalPath, itemPath, StringComparison.OrdinalIgnoreCase) ? "menu-item-active" : null;
    }

    public void Dispose() {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
===
@inject NavigationManager NavigationManager
@implements IDisposable

<div>
    @* --- Mobile Auth Menu (User profile / Log in) --- *@
    <DxMenu Orientation="@Orientation.Vertical" CssClass="menu display-mobile">
        <Items>
            <AuthorizeView>
                <Authorized>
                    <DxMenuItem NavigateUrl="Account/Manage" Text="@context.User.Identity?.Name" CssClass="@MenuItemCssClass("/Account/Manage")" IconCssClass="icon icon-user"></DxMenuItem>
                    <DxMenuItem NavigateUrl="Account/Logout" Text="Log out" CssClass="@MenuItemCssClass("/Account/Logout")" IconCssClass="icon icon-log-out"></DxMenuItem>
                </Authorized>
                <NotAuthorized>
                    <DxMenuItem NavigateUrl="Account/Login" Text="Log in" CssClass="@MenuItemCssClass("/Account/Login")" IconCssClass="icon icon-log-in"></DxMenuItem>
                </NotAuthorized>
            </AuthorizeView>
        </Items>
    </DxMenu>

    @* --- Main Navigation (visible to all authenticated users) --- *@
    <DxMenu Orientation="@Orientation.Vertical" CssClass="menu">
        <Items>
            <DxMenuItem NavigateUrl="/" Text="Home" CssClass="@MenuItemCssClass("/")" IconCssClass="icon icon-home"></DxMenuItem>
            <DxMenuItem NavigateUrl="/dashboard" Text="Dashboard" CssClass="@MenuItemCssClass("/dashboard")" IconCssClass="icon icon-counter"></DxMenuItem>
        </Items>
    </DxMenu>

    @* --- Admin Navigation (SuperAdmin + Admin only) --- *@
    <AuthorizeView Roles="SuperAdmin, Admin">
        <Authorized>
            <DxMenu Orientation="@Orientation.Vertical" CssClass="menu">
                <Items>
                    <DxMenuItem NavigateUrl="/admin/users" Text="User Management" CssClass="@MenuItemCssClass("/admin/users")" IconCssClass="icon icon-user"></DxMenuItem>
                </Items>
            </DxMenu>
        </Authorized>
    </AuthorizeView>

    @* --- SuperAdmin-only Navigation --- *@
    <AuthorizeView Roles="SuperAdmin">
        <Authorized>
            <DxMenu Orientation="@Orientation.Vertical" CssClass="menu">
                <Items>
                    <DxMenuItem NavigateUrl="/admin/settings" Text="System Settings" CssClass="@MenuItemCssClass("/admin/settings")" IconCssClass="icon icon-settings"></DxMenuItem>
                </Items>
            </DxMenu>
        </Authorized>
    </AuthorizeView>

    @* --- Account Settings (all authenticated) --- *@
    <DxMenu Orientation="@Orientation.Vertical" CssClass="menu">
        <Items>
            <DxMenuItem NavigateUrl="Account/Manage" Text="My Account" CssClass="@MenuItemCssClass("/Account/Manage")" IconCssClass="icon icon-settings"></DxMenuItem>
        </Items>
    </DxMenu>
</div>

@code {
    private string? currentLocalPath;

    protected override void OnInitialized() {
        currentLocalPath = new Uri(NavigationManager.Uri).LocalPath;
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e) {
        currentLocalPath = new Uri(NavigationManager.Uri).LocalPath;
        InvokeAsync(StateHasChanged);
    }

    private string? MenuItemCssClass(string itemPath) {
        return string.Equals(currentLocalPath, itemPath, StringComparison.OrdinalIgnoreCase) ? "menu-item-active" : null;
    }

    public void Dispose() {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
```

### [MainLayout.razor](file:///c:/Users/Admin/source/Workspaces/2026/Vns-Epr-Blazor-2026/Vns-Epr-Blazor-2026/Vns-Epr-Blazor-2026/Components/Layout/MainLayout.razor)

Replaced DevExpress Docs/Demos footer links with **"VNS ERP 2026"** branding.

```diff:MainLayout.razor
@inherits DrawerStateLayoutComponentBase
@implements IDisposable
@inject NavigationManager NavigationManager

<div class="page">
    <Drawer CssClass="navigation-drawer" PanelWidth="240px">
        <HeaderTemplate>
            <div class="navigation-drawer-header">
                <NavLink href="@AddDrawerStateToUrl("/")">
                    <img class="logo" src="images/logo.svg" alt="DevExpress logo" />
                </NavLink>
                <NavLink aria-label="Close menu" href="@AddDrawerStateToUrlToggled(LocalPath)">
                    <DxButton aria-label="Close menu" RenderStyle="ButtonRenderStyle.Light" RenderStyleMode="ButtonRenderStyleMode.Text" CssClass="btn-icon-only" IconCssClass="@(ToggledDrawer ? "icon icon-close" : "icon icon-menu")"></DxButton>
                </NavLink>
            </div>
        </HeaderTemplate>
        <BodyTemplate>
            <div class="w-100">
                <NavMenu></NavMenu>
            </div>
        </BodyTemplate>
        <FooterTemplate>
            <div class="navigation-drawer-footer">
                <NavLink href="https://docs.devexpress.com/Blazor/400725/blazor-components" class="button-link">
                    <DxButton Text="Docs" RenderStyle="ButtonRenderStyle.Light" RenderStyleMode="ButtonRenderStyleMode.Text" IconCssClass="icon icon-docs"></DxButton>
                </NavLink>
                <NavLink href="https://demos.devexpress.com/blazor/" class="button-link">
                    <DxButton Text="Demos" RenderStyle="ButtonRenderStyle.Light" RenderStyleMode="ButtonRenderStyleMode.Text" IconCssClass="icon icon-demos"></DxButton>
                </NavLink>
            </div>
        </FooterTemplate>
        <TargetContent>
            <div class="drawer-content">
                <div class="nav-buttons-container">
                    <NavLink aria-label="Open menu" href="@AddDrawerStateToUrlToggled(LocalPath)" class="menu-button">
                        <DxButton aria-label="Open menu" RenderStyle="ButtonRenderStyle.Secondary" RenderStyleMode="ButtonRenderStyleMode.Text" CssClass="btn-icon-only" IconCssClass="icon icon-menu"></DxButton>
                    </NavLink>
                    @if (LocalPath != "/") {
                        <NavLink href="@AddDrawerStateToUrl("/")" class="button-link">
                            <DxButton Text="Back to Home" RenderStyle="ButtonRenderStyle.Secondary" RenderStyleMode="ButtonRenderStyleMode.Text" CssClass="back-button" IconCssClass="icon icon-back"></DxButton>
                        </NavLink>
                    }
                    <AuthorizeView>
                        <Authorized>
                            <NavLink href="@AddDrawerStateToUrl("Account/Manage")" class="button-link menu-button-float-end display-desktop">
                                <DxButton Text="@context.User.Identity?.Name" RenderStyle="ButtonRenderStyle.Secondary" RenderStyleMode="ButtonRenderStyleMode.Text" IconCssClass="icon icon-user"></DxButton>
                            </NavLink>
                            <form action="@AddDrawerStateToUrl("Account/Logout")" method="post" class="display-desktop">
                                <AntiforgeryToken />
                                <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                                <DxButton SubmitFormOnClick="true" Text="Log out" RenderStyle="ButtonRenderStyle.Secondary" RenderStyleMode="ButtonRenderStyleMode.Text" IconCssClass="icon icon-log-out"></DxButton>
                            </form>
                        </Authorized>
                        <NotAuthorized>
                            <NavLink href="@AddDrawerStateToUrl("Account/Login")" class="button-link menu-button-float-end display-desktop">
                                <DxButton Text="Log in" RenderStyle="ButtonRenderStyle.Secondary" RenderStyleMode="ButtonRenderStyleMode.Text" IconCssClass="icon icon-log-in"></DxButton>
                            </NavLink>
                        </NotAuthorized>
                    </AuthorizeView>
                </div>
                <div class="page-content-container">
                    @Body
                </div>
            </div>
        </TargetContent>
    </Drawer>
</div>

@code {
    string LocalPath => new Uri(NavigationManager.Uri).LocalPath;

    private string? currentUrl;

    protected override void OnInitialized() {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e) {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose() {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
